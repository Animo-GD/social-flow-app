# ─────────────────────────────────────────────────────────────────────────────
# SocialFlow — Environment Variables Template
# Copy this to .env.local and fill in your values.
# NEVER commit .env.local to Git.
# ─────────────────────────────────────────────────────────────────────────────

# ── App URL ──────────────────────────────────────────────────────────────────
# Dev:        http://localhost:3000
# Production: https://your-coolify-domain.com
NEXT_PUBLIC_API_URL=http://localhost:3000

# ── Supabase ─────────────────────────────────────────────────────────────────
# From: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...your_anon_key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...your_service_role_key

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-a-long-random-secret-32-chars-min
NEXTAUTH_URL=http://localhost:3000
SESSION_COOKIE_SECURE=false



# ── Database (direct connection — for migrations only) ───────────────────────
# If your password contains # wrap the whole value in single quotes in shell.
# In Coolify env UI: paste the raw value, no quotes needed.
DATABASE_URL=postgresql://postgres.bkwggmsukawvofmtydux:YOUR_PASSWORD@aws-1-eu-central-1.pooler.supabase.com:5432/postgres

# ── n8n Webhooks ─────────────────────────────────────────────────────────────
# Content generation (required)
N8N_CONTENT_GENERATE_URL=https://your-n8n.com/webhook/generate-content

# Post scheduling notify (optional)
N8N_POST_SCHEDULE_URL=https://your-n8n.com/webhook/post-schedule
